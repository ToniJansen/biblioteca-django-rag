# Modelo de arquivo de variaveis sensiveis do biblioteca_mvp.
# Copie este arquivo para .env e edite com suas credenciais reais.
# O .env NAO vai pro Git (ver .gitignore); o .env.example VAI pro Git.

# ---------------------------------------------------------------------------
# Django
# ---------------------------------------------------------------------------

# SECRET_KEY do Django. Gere uma nova com:
#   python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
# Em producao, NUNCA use a chave de desenvolvimento do fallback em settings.py.
DJANGO_SECRET_KEY=coloque-sua-secret-key-aqui

# DEBUG: true apenas em desenvolvimento local. Em producao deixe false ou vazio.
DJANGO_DEBUG=true

# ALLOWED_HOSTS: dominios/IPs autorizados, separados por virgula.
# Em dev local, localhost,127.0.0.1 e suficiente.
# Em producao, liste os dominios reais (ex: biblioteca.ufg.br,www.biblioteca.ufg.br).
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# ---------------------------------------------------------------------------
# Chat RAG (Groq)
# ---------------------------------------------------------------------------

# Chave da API da Groq — gere em https://console.groq.com
# Formato: gsk_... (cerca de 60 caracteres)
GROQ_API_KEY=COLAR_SUA_KEY_AQUI

# Modelo padrao da Groq. Candidatos:
#   llama-3.3-70b-versatile        -> melhor qualidade pt-br (recomendado)
#   llama-3.1-8b-instant           -> mais rapido, qualidade menor
#   mixtral-8x7b-32768             -> contexto longo
#   deepseek-r1-distill-llama-70b  -> reasoning detalhado
GROQ_MODEL=llama-3.3-70b-versatile
